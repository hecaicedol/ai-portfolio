# LLM
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# Database
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=pipeline_dev
POSTGRES_DB=pipeline
DATABASE_URL=postgresql+psycopg://pipeline:pipeline_dev@postgres:5432/pipeline

# Observability (Langfuse)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000

# Pipeline tuning
CRITIC_PASS_THRESHOLD=0.85
MAX_REFLECTION_ITERATIONS=3
EMBEDDING_MODEL=voyage-3
VOYAGE_API_KEY=
